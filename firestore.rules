rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAdmin() {
      // Check for the existence of the user's UID in the 'admins' collection.
      // This is secure and efficient.
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    // Admin roles are managed from the Firebase Console, not by clients.
    match /admins/{userId} {
      // Allows only the owner of the UID to check their status, or admins.
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if false; // DENY all client writes.
    }

    // Site configuration is publicly readable but only admin-writable.
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Casos de éxito (Success Stories) públicos y UI Dinámica
    match /success_stories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Consultation creation is now handled exclusively by a secure server-side API route.
    // Therefore, all direct client writes are denied.
    match /consultations/{consultationId} {
      // DENY ALL client-side creation, update, or deletion.
      allow write: if false;
      
      // Admins can read consultation documents from the admin panel.
      allow read: if isAdmin();
    }

    // Índice ciego (Validación O(1) Edge Serverless) - Opción 1
    match /consultas_index/{hashId} {
      // allow list: if false; // Por defecto no se puede listar
      allow get: if true; // API público solo puede consultar un hash específico
      allow write: if false; // Solo administradores o Cloud Functions (Admin SDK)
    }
  }
}
