# ─── SERVICIOS CORE ───────────────────────────────────────
# GEMINI_API_KEY (Removido - No IA)
NEXT_PUBLIC_SITE_URL=http://localhost:9005
NEXT_PUBLIC_BRAND_NAME=Desmulta

# ─── CLOUDFLARE TURNSTILE (Seguridad Anti-Bot) ─────────────
# Público: Para renderizar el widget en el cliente
NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu_site_key_aqui
# Privado: Solo para validación en el servidor (create-consultation)
TURNSTILE_SECRET_KEY=tu_secret_key_aqui

# ─── FIREBASE CONFIG (Requerido para validación Edge REST) ─
# Firebase Admin (Producción)
# NOTA PARA VERCEL: Pegar la llave tal cual viene en el JSON de Firebase (incluyendo BEGIN/END y \n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQD... (ejemplo)\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@xxxxx.iam.gserviceaccount.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu_project_id
NEXT_PUBLIC_FIREBASE_API_KEY=tu_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── ANALÍTICA Y MARKETING ────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXX
NEXT_PUBLIC_PIXEL_ID=
NEXT_PUBLIC_WHATSAPP_NUMBER=573005648309
